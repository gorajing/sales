# .env.local.example — copy to .env.local and fill in.
#
# The Claude CLI uses your local OAuth session, so no Anthropic API key is
# required for the LLM runtime. The v2 scoring/routing pipeline DOES need a
# few env vars, documented below.

# ---------------------------------------------------------------------------
# REQUIRED for /api/scoring/recompute to succeed.
# Without this, any otherwise-valid recompute request (auth + content +
# accountId all OK) returns 503 misconfigured before computeScore runs.
# Malformed requests can still 4xx earlier (401/415/400). The value is
# the fallback owner the routing engine assigns to accounts that don't
# match any rule in data/routing-rules.md. Must look like an email
# (<local>@<host>.<tld>).
DEFAULT_OWNER_EMAIL=triage@example.com

# ---------------------------------------------------------------------------
# OPTIONAL in local dev, REQUIRED in production.
#
# /api/signals is the public webhook for ingesting third-party signals.
#   - When unset (NODE_ENV != production): the route runs permissively but
#     marks all ingested evidence as `pending_audit` (no trusted-sender flag),
#     so it can't influence scoring until an operator audits it.
#   - When set: the route requires `X-Webhook-Secret: <value>`. Comparison is
#     timing-safe.
#   - In NODE_ENV=production, leaving this unset → 503 fail-safe.
SIGNAL_WEBHOOK_SECRET=

# /api/scoring/recompute is an internal endpoint (cron jobs, dashboards,
# operator scripts). Same shape as SIGNAL_WEBHOOK_SECRET:
#   - Unset in dev: open. Set in dev: requires `X-Internal-Secret: <value>`.
#   - Unset in NODE_ENV=production: 503 fail-safe.
INTERNAL_API_SECRET=

# ---------------------------------------------------------------------------
# REQUIRED for the GitHub connector (lib/connectors/github.ts, Task 3.2).
#
# Personal access token used to call the GitHub Events API. Public repos
# need `public_repo` scope; private repos need `repo`. Read only by
# `GitHubConnector.fromEnv()` (the orchestrator factory); test code
# instantiates the connector directly with a fake events client and
# never touches this variable.
#
# Without it, `GitHubConnector.fromEnv()` throws ConnectorError at
# construction time with the message "GITHUB_TOKEN env var not set".
# Task 3.4 (poll orchestrator) decides the response policy — current
# plan: omit the connector from the registered set so the rest of the
# poller keeps working. Don't depend on this stanza for the precise
# orchestrator behavior; see Task 3.4 / its skill docs once landed.
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Add MCP server configs here if/when you wire Perplexity, ChatGPT MCP, etc.
